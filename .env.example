# --- Teacher (data generation): DeepSeek V4 Pro, top reasoning model ---
# Get a key at https://platform.deepseek.com/
DEEPSEEK_API_KEY=
TEACHER_MODEL=deepseek-v4-pro

# Teacher generation settings
TEACHER_TEMPERATURE=0.6
TEACHER_MAX_TOKENS=8192
TEACHER_TIMEOUT=600

# Concurrency + rate-limit resilience
TEACHER_CONCURRENCY=8
TEACHER_MAX_RETRIES=5
TEACHER_RETRY_BASE_DELAY=2

# --- Student (training + serving) ---
STUDENT_MODEL=Qwen/Qwen3-8B
HF_TOKEN=

# vLLM-served student (set after `modal serve modal_apps/serve.py`).
VLLM_API_BASE=
VLLM_API_KEY=EMPTY

# --- Start-small knobs (optional overrides) ---
# RESUME_SAMPLE_SIZE=30   # default: unset = use the entire dataset; set an int to sample
MAX_QUERIES_PER_RESUME=4
JOBS_PER_QUERY=5
JOBS_SLEEP_BETWEEN=3
# MAX_JOB_QUERIES=5   # cap total LinkedIn queries (handy for a quick smoke test)
# MAX_EVAL_PAIRS=60   # cap eval pairs / teacher calls (default: unlimited — evaluate all jobs)
