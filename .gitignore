# Python
__pycache__/
*.py[cod]
.venv/
*.egg-info/
.pytest_cache/
.ruff_cache/

# Env / secrets
.env

# Generated data — regenerated by gen-queries / fetch-jobs / gen-evals / to-sft.
# Heavy (jobs.jsonl ~50 MB, dataset2.jsonl ~240 MB, sft/fit_eval.train.jsonl ~240 MB).
#
# Anchored to the repo root on purpose. A bare `data/` also matches src/job_search/data/,
# and because hatchling honours .gitignore when selecting wheel contents, that silently
# built a wheel with no job_search.data package — fine locally (we import from src/), but
# any `pip install` of this project produced an import error on first use.
/data/

# HF upload artifacts (datasets rebuilt from data/*.jsonl; adapters pulled from Modal Volume;
# GGUF artifacts produced by modal_apps/convert_to_gguf.py)
hf_uploads/datasets/build/
hf_uploads/models/build/
hf_uploads/models_gguf/build/

# OS
.DS_Store
